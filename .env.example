DATABASE_URL=postgresql+asyncpg://diplom:diplom@localhost:5432/diplom_db
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# OpenRouter (LLM) — paste your key here
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_TIMEOUT_SECONDS=300

# Used by docker-compose for the db service
POSTGRES_USER=diplom
POSTGRES_PASSWORD=diplom
POSTGRES_DB=diplom_db
